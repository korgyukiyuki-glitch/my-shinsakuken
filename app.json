{
  "expo": {
    "name": "マイ診察券",
    "slug": "my-dental-card",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "mydental",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mydental.card",
      "buildNumber": "1",
      "infoPlist": {
        "NSFaceIDUsageDescription": "診察券データを保護するために生体認証を使用します",
        "NSCameraUsageDescription": "お薬手帳のシールや診察券を撮影するためにカメラを使用します",
        "CFBundleDisplayName": "マイ診察券",
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleLocalizations": ["ja", "en"],
        "CFBundleDevelopmentRegion": "ja"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.mydental.card",
      "predictiveBackGestureEnabled": false,
      "versionCode": 1,
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1a1a2e"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "診察券データを保護するために生体認証を使用します"
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "お薬手帳のシールを撮影するためにカメラを使用します"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.5"
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "da8e5135-f7f7-4b1c-b280-68ef484e9d3c"
      }
    },
    "owner": "korg0611"
  }
}
